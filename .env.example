# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: Your Supabase project URL
VITE_SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous API key
VITE_SUPABASE_ANON_KEY="your-anon-key"
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server runtime
PORT=3000
NODE_ENV=production

# ─── EMAIL SERVICES CONFIGURATION ──────────────────────────────────────────
# The system automatically chooses the driver based on configured variables:
# 1. SENDGRID_API_KEY -> Uses SendGrid HTTP API (Port 443, perfect for Render Free Tier)
# 2. GMAIL_USER & GMAIL_APP_PASSWORD -> Fallback Gmail SMTP (for Local development / Paid Tiers)
# 3. If none -> Falls back to Terminal/Outbox logs simulation (for local developer testing)

# The email address that will RECEIVE order alerts & contact form inquiries
SELLER_EMAIL="admin@ekokintsugi.com"

# Driver A: SendGrid HTTP API (Bypasses Render SMTP port blocking)
SENDGRID_API_KEY=""
SENDGRID_SENDER_EMAIL="" # Verified SendGrid sender address (defaults to GMAIL_USER or orders@ekokintsugi.com if empty)

# Driver B: Gmail SMTP App Password (Will fail on Render Free tier due to port blocking, works on localhost)
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-gmail-16-char-app-password"

